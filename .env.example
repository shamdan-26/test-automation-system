# ─────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in values for local runs.
# .env is gitignored — never commit real credentials.
# In Jenkins, use the Credentials Store instead of this file.
# ─────────────────────────────────────────────────────────────────

# Jira (only needed if Jira integration is enabled in tas_config.yml)
JIRA_SERVER_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=

# GitHub (only needed if GitHub integration is enabled)
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo

# SMTP (only needed if email notifications are enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
